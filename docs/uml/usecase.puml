@startuml
left to right direction
skinparam packageStyle rectangle
actor User
rectangle "COLORS Web Application" {
  usecase "Log In" as UC1
  usecase "Hash Password\nwith MD5" as UC2
  usecase "Store Session Cookie" as UC3
  usecase "Access Color Page" as UC4
  usecase "Add Color" as UC5
  usecase "Search Saved Colors" as UC6
  usecase "View Matching Colors" as UC7
  usecase "Log Out" as UC8
}
User --> UC1
User --> UC5
User --> UC6
User --> UC8
UC1 .> UC2 : <<include>>
UC1 .> UC3 : <<include>>
UC3 .> UC4 : <<include>>
UC6 .> UC7 : <<include>>
@enduml
